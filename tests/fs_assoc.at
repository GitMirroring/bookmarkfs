AT_SETUP([fs: tags and keywords])
AT_KEYWORDS([fs assoc tag keyword])

dnl
dnl  ATX_CHECK_FS_NEW_ASSOC([options], [prepare], [check])
dnl
m4_define([ATX_CHECK_FS_NEW_ASSOC], [
    ATX_CHECK_FS_NEW_FIREFOX([$1], [$2], [$3])
])

ATX_CHECK_FS_NEW_ASSOC([eol], , [
    tags_dir=../../tags
    keywords_dir=../../keywords

    ATX_RUN_REPEAT([8], [
        name=$(ath_fn_rand_u64_hex)
        tag=$(ath_fn_rand_u64_hex)
        keyword=$(ath_fn_rand_u64_hex)
        content=foo:$(ath_fn_rand_u64_hex)

        ATX_RUN([
            echo "$content/1" > $name-1
            echo "$content/2" > $name-2
            echo "$content/3" > $name-3
            mkdir "$tags_dir/$tag-1" "$tags_dir/$tag-2" "$tags_dir/$tag-3"

            ln $name-1 $name-2 "$tags_dir/$tag-1"
            ln $name-2 $name-3 "$tags_dir/$tag-2"
            ln $name-3 $name-1 "$tags_dir/$tag-3"
            test $name-1 -ef "$tags_dir/$tag-1/$name-1"
            test $name-1 -ef "$tags_dir/$tag-3/$name-1"
            test $name-2 -ef "$tags_dir/$tag-1/$name-2"
            test $name-2 -ef "$tags_dir/$tag-2/$name-2"
            test $name-3 -ef "$tags_dir/$tag-3/$name-3"
            test $name-3 -ef "$tags_dir/$tag-2/$name-3"

            ln $name-1 "$keywords_dir/$keyword-2"
            ln $name-2 "$keywords_dir/$keyword-3"
            ln $name-3 "$keywords_dir/$keyword-1"
            test $name-1 -ef "$keywords_dir/$keyword-2"
            test $name-2 -ef "$keywords_dir/$keyword-3"
            test $name-3 -ef "$keywords_dir/$keyword-1"

            rm "$tags_dir/$tag-1/$name-1"
            rm "$tags_dir/$tag-2/$name-2"
            rm "$tags_dir/$tag-3/$name-3"
            test ! -e "$tags_dir/$tag-1/$name-1"
            test ! -e "$tags_dir/$tag-2/$name-2"
            test ! -e "$tags_dir/$tag-3/$name-3"

            rm "$keywords_dir/$keyword-1"
            rm "$keywords_dir/$keyword-2"
            test ! -e "$keywords_dir/$keyword-1"
            test ! -e "$keywords_dir/$keyword-2"

            rm $name-1 $name-2 $name-3
            test ! -e "$tags_dir/$tag-1/$name-2"
            test ! -e "$tags_dir/$tag-2/$name-3"
            test ! -e "$tags_dir/$tag-3/$name-1"
            test ! -e "$keywords_dir/$keyword-3"
            rmdir "$tags_dir/$tag-1" "$tags_dir/$tag-2" "$tags_dir/$tag-3"
        ])
    ])
])

AT_CLEANUP
