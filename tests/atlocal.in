rand_u64_hex() {
    echo $(od -vAn -N8 -tx8 /dev/urandom | tr -d ' ')
}

rand_base64() {
    # The `base64` utility is not specified by POSIX,
    # but present in GNU Coreutils, BusyBox and FreeBSD base system.
    echo $(head -c$1 /dev/urandom | base64 -w0)
}
