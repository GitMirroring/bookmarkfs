AT_SETUP([misc: base16 encoding])
AT_KEYWORDS([misc base16])

ATX_CHECK_SIMPLE([
    check_base16() {
        check-misc base16 -d | check-misc base16
    }

    ATX_RUN_REPEAT([16], [
        str=$(od -vAn -N4096 -tx1 /dev/urandom | tr -d ' \n')

        ATX_RUN([
            test "$str" = "$(printf %s $str | check_base16)"
        ])
    ])
])

AT_CLEANUP
