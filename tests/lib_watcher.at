AT_SETUP([util lib: file watcher])
AT_KEYWORDS([lib watcher])

ATX_CHECK_LIB([
    args=
    ATX_FEAT_IF([native-watcher], , [
        args="$args -f"
    ])

    tmpdir=./$(ath_fn_rand_u64_hex).tmp.d

    mkdir $tmpdir
    check-bookmarkfs-util watcher $args $tmpdir
])

AT_CLEANUP
