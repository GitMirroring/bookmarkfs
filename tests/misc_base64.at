AT_SETUP([misc: base64 encoding])
AT_KEYWORDS([misc base64])

ATX_CHECK_SIMPLE([
    check_base64_decode() {
        tr '/+' '_-' | check-misc base64 -d
    }
    check_base64_encode() {
        check-misc base64 | tr '_-' '/+'
    }

    ATX_RUN_REPEAT([16], [
        str=$(ath_fn_rand_base64 3072)
        sum=$(printf %s $str | base64 -d | sha256sum)

        ATX_RUN([
            test "$str" = "$(printf %s $str | base64 -d | check_base64_encode)"
            test "$sum" = "$(printf %s $str | check_base64_decode | sha256sum)"
        ])
    ])
])

AT_CLEANUP
